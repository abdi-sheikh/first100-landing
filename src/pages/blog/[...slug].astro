---
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { listPublishedPosts, getPostBySlug } from '../../lib/blog/posts';
import { renderMarkdown } from '../../lib/blog/render';

export async function getStaticPaths() {
  const posts = await listPublishedPosts('first100');
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing slug');

const post = await getPostBySlug(slug);
if (!post) throw new Error(`Post not found: ${slug}`);

const renderedHtml = await renderMarkdown(post.body_md);
---

<BlogPostLayout post={post} renderedHtml={renderedHtml} />
