---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { listPublishedPosts } from '../../lib/blog/posts';

const posts = await listPublishedPosts('first100');
---

<BaseLayout
  title="Blog | First 100"
  description="Language development, parenting, and the science of how kids learn words. From the team at First 100."
>
  <Header slot="header" />

  <main id="main-content" class="blog-index">
    <header class="blog-index__header">
      <h1>The First 100 blog</h1>
      <p>Language development, parenting, and the science of how kids learn words.</p>
    </header>

    {posts.length === 0 ? (
      <p class="blog-index__empty">No posts published yet — new writing coming soon.</p>
    ) : (
      <div class="blog-index__grid">
        {posts.map((post) => <BlogPostCard post={post} />)}
      </div>
    )}
  </main>

  <Footer slot="footer" />
</BaseLayout>

<style>
.blog-index {
  max-width: 1100px;
  margin: 0 auto;
  padding: 3rem 1.25rem 4rem;
}
.blog-index__header {
  margin-bottom: 3rem;
  text-align: center;
}
.blog-index__header h1 {
  font-size: clamp(2.2rem, 5vw, 3.2rem);
  margin: 0 0 0.75rem;
  color: var(--color-text);
}
.blog-index__header p {
  font-size: 1.15rem;
  color: var(--color-text-muted);
  margin: 0;
}
.blog-index__grid {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
}
.blog-index__empty {
  text-align: center;
  color: var(--color-text-muted);
  font-size: 1.1rem;
  padding: 3rem 0;
}
</style>
