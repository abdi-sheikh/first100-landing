---
import { withBase } from '../utils/withBase';
import type { BlogPostListItem } from '../lib/blog/types';

interface Props { post: BlogPostListItem; }
const { post } = Astro.props;

const href = withBase(`/blog/${post.slug}`);
const pubDateDisplay = post.pub_date
  ? new Date(post.pub_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;
---

<a class="blog-card" href={href}>
  {post.hero_image_url && (
    <img class="blog-card__hero" src={post.hero_image_url} alt={post.hero_image_alt ?? ''} loading="lazy" />
  )}
  <div class="blog-card__body">
    <p class="blog-card__category">{post.category.replace('-', ' ')}</p>
    <h2 class="blog-card__title">{post.title}</h2>
    <p class="blog-card__description">{post.description}</p>
    <p class="blog-card__meta">
      {post.author}{pubDateDisplay && ` · ${pubDateDisplay}`}
    </p>
  </div>
</a>

<style>
.blog-card {
  display: flex;
  flex-direction: column;
  padding: 1.5rem;
  border-radius: 12px;
  background: var(--color-surface);
  border: 1px solid rgba(0, 0, 0, 0.06);
  text-decoration: none;
  color: inherit;
  transition: transform 150ms ease, box-shadow 150ms ease;
}
.blog-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 18px rgba(0, 0, 0, 0.08);
}
.blog-card__hero {
  width: 100%;
  height: 160px;
  object-fit: cover;
  border-radius: 8px;
  margin-bottom: 1rem;
}
.blog-card__category {
  text-transform: uppercase;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  color: var(--color-accent);
  margin: 0 0 0.5rem;
}
.blog-card__title {
  margin: 0 0 0.5rem;
  font-size: 1.35rem;
  line-height: 1.2;
  color: var(--color-text);
}
.blog-card__description {
  margin: 0 0 1rem;
  font-size: 1rem;
  line-height: 1.5;
  color: var(--color-text-muted);
  flex-grow: 1;
}
.blog-card__meta {
  margin: 0;
  font-size: 0.85rem;
  color: var(--color-text-muted);
}
</style>
